# Databricks Model Serving configuration
# For local testing, copy this file to `.env.local` and fill in the values below.

# The URL of the served SARIMAX model endpoint (e.g., https://<databricks-instance>/serving-endpoints/<endpoint-name>/invocations)
VITE_DATABRICKS_ENDPOINT_URL=https://your-databricks-instance.cloud.databricks.com/serving-endpoints/retail_demand_forecaster/invocations

# Databricks Personal Access Token (PAT)
VITE_DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
